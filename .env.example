# Social Tracker proxy (Vercel) — set these as Environment Variables in the Vercel project.
# Never commit real values; .env is gitignored.

# Primary Postgres connection string.
POSTGRES_URL=

# Optional but recommended on serverless: a TRANSACTION-MODE pooled connection string
# (PgBouncer / Neon pooled endpoint / Supabase port 6543). The code prefers this if set.
POSTGRES_URL_POOLED=

# Optional: max DB connections per serverless instance (default 1).
PG_POOL_MAX=1

# DeepSeek AI key (used by /api/ai/* endpoints), if you use those features.
DEEPSEEK_API_KEY=
