{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-scheduled",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    { "source": "/s/:id", "destination": "/api/s/:id" },
    { "source": "/img/:id", "destination": "/api/img/:id" }
  ]
}
